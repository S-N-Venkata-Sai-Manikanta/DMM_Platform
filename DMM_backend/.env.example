# ===== Server =====
PORT=5000
NODE_ENV=development

# ===== Database =====
MONGO_URI=mongodb://localhost:27017/dmm_platform

# ===== Auth =====
# Generate a long random string, e.g.: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_this_with_a_long_random_secret_string
JWT_EXPIRES_IN=7d

# ===== Frontend (CORS + email links) =====
# Comma-separated list of allowed origins. First entry is used for email links.
# 5173 = main product (DMM_frontend), 5174 = admin portal (DMM_Admin)
CLIENT_URL=http://localhost:5173,http://localhost:5174

# ===== File Storage =====
# "local" stores uploads on disk; "cloudinary" uploads to Cloudinary.
STORAGE_DRIVER=local

# ===== Cloudinary (only if STORAGE_DRIVER=cloudinary) =====
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ===== Email / SMTP (optional) =====
# Required for self-service password reset and welcome emails.
# If left blank, password reset must be done by an admin from the admin panel.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=DMM Platform <no-reply@yourdomain.com>
